# Environment variables (copy to `.env.local` — never commit secrets)

# Resend — contact form delivery (https://resend.com)
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. "InnaYa <onboarding@resend.dev>"
RESEND_FROM=

# Optional override for inquiry recipient (defaults to studio Gmail in code)
CONTACT_TO=
